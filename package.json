{
  "name": "script-action",
  "type": "module",
  "version": "2.0.1",
  "description": "GitHub Action for executing TypeScript/JavaScript scripts in workflows",
  "author": "AliuQ",
  "license": "MIT",
  "keywords": [
    "github",
    "action",
    "typescript",
    "bun",
    "tsx"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prerelease": "bun run lint && bun run typecheck && bun run test && bun run build",
    "release": "bunx bumpp --push --tag --commit --all"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@types/bun": "^1.1.14",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "handlebars": "^4.7.9",
    "kolorist": "^1.8.0",
    "lefthook": "^2.1.4",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
